# ──────────────────────────────────────────────────────────────
# AIDA — OOI RCA Copilot  |  secrets.toml template
# ──────────────────────────────────────────────────────────────
# Copy this file to  .streamlit/secrets.toml  and fill in values.
# On Streamlit Cloud, paste these into the app's Secrets dashboard.
# NEVER commit the real secrets.toml to version control.
# ──────────────────────────────────────────────────────────────

# OOI M2M API Credentials
# Get yours at https://ooinet.oceanobservatories.org/ → Profile
OOI_USERNAME = ""
OOI_TOKEN = ""

# Fireworks AI (cloud LLM provider)
# Get a key at https://fireworks.ai/api-keys
FIREWORKS_API_KEY = ""

# Google OAuth2  (required for authentication)
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""

# Redirect URI — override for Streamlit Cloud deployment
# OAUTH_REDIRECT_URI = "https://your-app.streamlit.app"
